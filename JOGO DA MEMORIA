<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jogo da Memória vs Computador</title>
<style>
    body{
        font-family: Arial;
        text-align:center;
        background: linear-gradient(135deg,#4facfe,#00f2fe);
        color:white;
    }

    h1{
        margin-top:20px;
    }

    .placar{
        font-size:22px;
        margin:20px;
    }

    .tabuleiro{
        display:grid;
        grid-template-columns: repeat(4,100px);
        gap:10px;
        justify-content:center;
    }

    .carta{
        width:100px;
        height:100px;
        background:white;
        color:black;
        font-size:40px;
        display:flex;
        align-items:center;
        justify-content:center;
        cursor:pointer;
        border-radius:10px;
    }

    .virada{
        background:yellow;
    }

    button{
        margin-top:20px;
        padding:10px 20px;
        font-size:18px;
        border:none;
        border-radius:8px;
        cursor:pointer;
    }
</style>
</head>
<body>

<h1>🧠 Jogo da Memória vs Computador</h1>

<div class="placar">
    Você: <span id="jogador">0</span> |
    Computador: <span id="pc">0</span>
</div>

<div class="tabuleiro" id="tabuleiro"></div>

<button onclick="reiniciar()">Reiniciar</button>

<script>
const emojis = ["🍎","🍎","🚗","🚗","⚽","⚽","🐱","🐱",
                "🎵","🎵","🌞","🌞","🍕","🍕","🎮","🎮"];

let cartas = [];
let primeira = null;
let segunda = null;
let bloqueado = false;

let pontosJogador = 0;
let pontosPC = 0;
let turno = "jogador";

function embaralhar(array){
    return array.sort(() => Math.random() - 0.5);
}

function criarTabuleiro(){
    cartas = embaralhar([...emojis]);
    const tabuleiro = document.getElementById("tabuleiro");
    tabuleiro.innerHTML = "";

    cartas.forEach((emoji,index)=>{
        const carta = document.createElement("div");
        carta.classList.add("carta");
        carta.dataset.valor = emoji;
        carta.dataset.index = index;
        carta.innerHTML = "?";

        carta.addEventListener("click",()=>{
            if(turno !== "jogador") return;
            virarCarta(carta);
        });

        tabuleiro.appendChild(carta);
    });
}

function virarCarta(carta){
    if(bloqueado) return;
    if(carta.innerHTML !== "?") return;

    carta.innerHTML = carta.dataset.valor;
    carta.classList.add("virada");

    if(!primeira){
        primeira = carta;
    } else {
        segunda = carta;
        bloqueado = true;

        setTimeout(verificarPar,1000);
    }
}

function verificarPar(){
    if(primeira.dataset.valor === segunda.dataset.valor){
        if(turno === "jogador"){
            pontosJogador++;
            document.getElementById("jogador").innerText = pontosJogador;
        }else{
            pontosPC++;
            document.getElementById("pc").innerText = pontosPC;
        }
    }else{
        primeira.innerHTML = "?";
        segunda.innerHTML = "?";
        primeira.classList.remove("virada");
        segunda.classList.remove("virada");

        turno = turno === "jogador" ? "pc" : "jogador";

        if(turno === "pc"){
            setTimeout(jogadaComputador,1000);
        }
    }

    primeira = null;
    segunda = null;
    bloqueado = false;

    verificarFim();
}

function jogadaComputador(){
    let disponiveis = [...document.querySelectorAll(".carta")]
        .filter(c => c.innerHTML === "?");

    if(disponiveis.length < 2) return;

    let c1 = disponiveis[Math.floor(Math.random()*disponiveis.length)];
    virarPC(c1);

    disponiveis = disponiveis.filter(c => c !== c1);

    let c2 = disponiveis[Math.floor(Math.random()*disponiveis.length)];
    virarPC(c2);

    setTimeout(verificarPar,1000);
}

function virarPC(carta){
    carta.innerHTML = carta.dataset.valor;

    if(!primeira){
        primeira = carta;
    }else{
        segunda = carta;
    }
}

function verificarFim(){
    let restantes = [...document.querySelectorAll(".carta")]
        .filter(c => c.innerHTML === "?");

    if(restantes.length === 0){
        if(pontosJogador > pontosPC){
            alert("🎉 Você venceu!");
        }else if(pontosPC > pontosJogador){
            alert("🤖 Computador venceu!");
        }else{
            alert("Empate!");
        }
    }
}

function reiniciar(){
    pontosJogador = 0;
    pontosPC = 0;
    document.getElementById("jogador").innerText = 0;
    document.getElementById("pc").innerText = 0;
    turno = "jogador";
    primeira = null;
    segunda = null;
    criarTabuleiro();
}

criarTabuleiro();
</script>

</body>
</html>
